# ----------------------------------------------------------------------------
# Caissie Canine Instruction — environment variables
# Copy this file to ".env.local" and fill in the values. Never commit .env.local
# ----------------------------------------------------------------------------

# Public site URL (used for canonical URLs, sitemap, Open Graph, JSON-LD)
NEXT_PUBLIC_SITE_URL="https://caissiecanineinstruction.ca"

# ----------------------------------------------------------------------------
# Inquiry form -> SMS notification (Twilio, primary path)


# Where new-lead texts are sent (E.164). Change anytime.
OWNER_SMS_NUMBER="+16475104080"

# ----------------------------------------------------------------------------
# Optional backup: also forward each lead to a Zapier webhook for logging
# (e.g. Catch Hook -> Google Sheets / Airtable). Leave blank to skip.
# ----------------------------------------------------------------------------
INQUIRY_WEBHOOK_URL=""

# Optional shared secret echoed to the webhook so Zapier can reject spoofed calls
INQUIRY_WEBHOOK_SECRET=""

# Optional: simple fallback email target shown in UI (not used to send directly)
NEXT_PUBLIC_CONTACT_EMAIL="Caissiecanineinstruction@gmail.com"
NEXT_PUBLIC_CONTACT_PHONE="905 427 4142"

# ----------------------------------------------------------------------------
# Analytics (optional). Leave blank to disable.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_CLARITY_ID=""
